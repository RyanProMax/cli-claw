{
  "name": "cli-claw-kit",
  "version": "0.0.4",
  "description": "Self-hosted multi-user AI agent platform powered by CLI runtimes.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "cli-claw": "dist/cli.js"
  },
  "files": [
    "dist",
    "config",
    "shared",
    "shared/dist",
    "container/build.sh",
    "container/Dockerfile",
    "container/entrypoint.sh",
    "container/skills",
    "container/agent-runner/package.json",
    "container/agent-runner/dist",
    "container/agent-runner/prompts",
    "web/dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run build:shared && npm run build:backend && npm run build:web && npm --prefix container/agent-runner run build:runner",
    "prepack": "npm run build",
    "release:check": "bash ./scripts/release-check.sh",
    "start": "bun src/index.ts",
    "reset:admin": "tsx src/reset-admin.ts",
    "typecheck": "npm run build:shared && npm run typecheck:backend",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "vitest",
    "build:web": "npm --prefix web run build",
    "build:shared": "tsc -p shared/tsconfig.json",
    "build:backend": "tsc",
    "typecheck:backend": "tsc --noEmit"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.18.0",
    "@anthropic-ai/claude-agent-sdk": "^0.2.85",
    "@hono/node-server": "^1.19.9",
    "@larksuiteoapi/node-sdk": "^1.58.0",
    "@types/qrcode": "^1.5.6",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^11.8.1",
    "cron-parser": "^5.5.0",
    "dingtalk-stream": "2.1.6-beta.1",
    "grammy": "^1.40.0",
    "hono": "^4.11.9",
    "node-pty": "^1.1.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "proxy-agent": "^6.5.0",
    "qrcode": "^1.5.4",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.2.1",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.1"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RyanProMax/cli-claw.git"
  },
  "homepage": "https://github.com/RyanProMax/cli-claw#readme",
  "bugs": {
    "url": "https://github.com/RyanProMax/cli-claw/issues"
  },
  "author": "riba2534",
  "keywords": [
    "claude",
    "claude-code",
    "codex",
    "ai-agent",
    "self-hosted",
    "feishu",
    "lark",
    "telegram",
    "chatbot",
    "docker",
    "mcp"
  ]
}
